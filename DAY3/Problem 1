# Create an empty list to store student details
students = []

# Number of students
n = int(input())

# Collect student data
for i in range(n):
    name = input()              # Read student name
    grade = float(input())     # Read student grade
    students.append([name, grade])  # Store as [name, grade]

# Extract unique grades and sort them
grades = sorted(set([s[1] for s in students]))

# Get the second lowest grade
second_lowest = grades[1]

# Find all students with the second lowest grade
names = [s[0] for s in students if s[1] == second_lowest]

# Sort names alphabetically
names.sort()

# Print each name
for name in names:
    print(name)
