# Create empty list to store student data
students = []

# Number of students
n = int(input())

# Input student details
for i in range(n):
    name = input()              # Read name
    grade = float(input())      # Read grade
    students.append([name, grade])

# Find the highest grade
max_grade = max([s[1] for s in students])

# Get names of students with highest grade
top_students = [s[0] for s in students if s[1] == max_grade]

# Sort names alphabetically
top_students.sort()

# Print names
for name in top_students:
    print(name)
